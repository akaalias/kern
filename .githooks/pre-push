#!/bin/sh
# pre-push — gate every push on the same three checks CI runs, locally, before
# anything reaches the remote. Any failure aborts the push.
#
#   1. Headless core tests   (ASan/UBSan)
#   2. Core line coverage    (>= 85% floor, same as CI)
#   3. Performance smoke      (--check budgets)
#
# Bypass for a single push (e.g. docs-only WIP):  git push --no-verify
# Override the perf corpus path:                  KERN_PERF_CORPUS=/path git push
#
# Activated via:  git config core.hooksPath .githooks   (run once per clone)
set -eu

cd "$(git rev-parse --show-toplevel)"

echo "==> pre-push 1/3: headless core tests"
make -C tests --no-print-directory test

echo "==> pre-push 2/3: core coverage (>= 85% lines)"
# Same target CI runs (tests/Makefile coverage-check) — the floor is enforced
# from llvm-cov's export JSON, so this mirrors CI exactly and can't drift.
if ! make -C tests --no-print-directory coverage-check; then
  echo "pre-push: core coverage below the floor (or build failed) — push aborted" >&2
  exit 1
fi

echo "==> pre-push 3/3: performance smoke"
corpus="${KERN_PERF_CORPUS:-$(pwd)/tests/perf_corpus.txt}"
if [ ! -f "$corpus" ]; then
  echo "   generating 25MB perf corpus (one-time): $corpus"
  python3 tools/gen_prose.py 25MB "$corpus"
fi
make -C tests --no-print-directory perf CORPUS="$corpus" PERF_ARGS=--check

echo "==> pre-push: all checks passed"
